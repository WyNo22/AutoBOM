# =================== Web app ===================
# DB connection (libSQL — works for local file and Turso cloud).
# Local SQLite file (default, dev):
DATABASE_URL=file:./autbom.db
# Turso cloud (prod):
# DATABASE_URL=libsql://<your-db>.turso.io
# TURSO_AUTH_TOKEN=...

# Storage driver: "fs" (dev) or "s3" (prod)
STORAGE_DRIVER=fs
STORAGE_FS_DIR=./storage
# When STORAGE_DRIVER=s3
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Auth.js
AUTH_SECRET=replace-me-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Magic link mail driver: "console" (dev: log link to stdout) or "resend" (prod)
MAIL_DRIVER=console
# RESEND_API_KEY=
# MAIL_FROM=AUTBOM <noreply@example.com>
